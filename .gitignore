# ═══════════════════════════════════════════════════════════════
# JobMatch .gitignore
# ═══════════════════════════════════════════════════════════════
 
# ── Raw datasets (too large for GitHub) ───────────────────────
data/raw/
 
# ── Processed/generated data ──────────────────────────────────
data/processed/
data/indexes/
 
# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
env/
.venv/
 
# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
 
# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
 
# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
 
# ── Misc ──────────────────────────────────────────────────────
*.zip
*.tar.gz

# ── AI/Claude files ───────────────────────────────────────────
.claude/
CLAUDE.md

# ── Generated outputs ─────────────────────────────────────────
eval_output.txt